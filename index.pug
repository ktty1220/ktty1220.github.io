doctype html
html(lang='ja')
  head
    meta(charset='UTF-8')
    //meta(name='viewport', content='initial-scale=1')
    meta(name='description', content='ktty1220のポートフォリオ')
    title ktty1220@Portfolio
    -
      var cssList = [
        'normalize',
        'clearfix',
        'bootstrap.min',
        'style'
      ];
    - cssList.forEach(function (css) {
      link(rel='stylesheet', href='css/' + css + '.css')
    - });
    != '\n    <!--[if lt IE 9]>'
    script(src='https://html5shiv.googlecode.com/svn/trunk/html5.js')
    != '\n    <![endif]-->'
    script(src='https://ajax.googleapis.com/ajax/libs/jquery/1.11.2/jquery.min.js')

  body
    div#wrap
      div#content.content
        div.row-fluid
          div.span4
            div.box
              h1
                img(src='img/under_construction_normal.png', alt='avatar')
                span ktty1220
              h2 About Me
              p.
                個人でWebサービスをいくつか運営しています。Webサービスの運営で飯を食べていけるよう修行中です。（達成度#[span.percent 0.5%])
              -
                var favicon = function (url) {
                  if (/play\.google\.com/.test(url)) {
                    return 'https://ssl.gstatic.com/android/market_images/web/favicon.ico';
                  }
                  return url.replace(/(:\/\/[^/]+)\/.*$/, '$1/favicon.ico');
                };
              h2 Services
              -
                var services = {
                  Twitter: {
                    link: 'https://twitter.com/ktty1220',
                    favicon: 'https://abs.twimg.com/favicons/favicon.ico'
                  },
                  Qiita: {
                    link: 'http://qiita.com/ktty1220',
                    favicon: 'https://cdn.qiita.com/assets/favicons/public/production-4ff10c1e1e2b5fcb353ff9cafdd56c70.ico'
                  },
                  GitHub: {
                    link: 'https://github.com/ktty1220',
                    favicon: 'https://github.githubassets.com/favicon.ico'
                  },
                  npm: {
                    link: 'https://npmjs.org/~ktty1220',
                    favicon: 'https://static.npmjs.com/3dc95981de4241b35cd55fe126ab6b2c.png'
                  },
                  GooglePlay: {
                    link: 'https://play.google.com/store/apps/developer?id=ktty1220',
                    favicon: 'https://ssl.gstatic.com/android/market_images/web/favicon.ico'
                  }
                };
              ul#services
                each info, name in services
                  li
                    a(href=info.link, target='_blank')
                      img.favicon(src=info.favicon, alt=name)
                      span #{name}

              h2 Skill
              -
                var skills = [
                  'Node.js',
                  'JavaScript(ES5, ES6, jQuery)',
                  'TypeScript',
                  'CoffeeScript',
                  'HTML5',
                  'CSS3',
                  'PHP(CakePHP)',
                  'Lua',
                  'Perl',
                  'MySQL',
                  'PostgreSQL',
                  'SQLite3',
                  'MongoDB',
                  'Redis',
                  'Apache',
                  'Nginx',
                  'C/C++',
                  'Android App',
                  'Linux(ubuntu, CentOS)',
                  'Heroku',
                  'OpenShift'
                ];
              ul#skill
                - skills.forEach(function (skill) {
                  li #{skill}
                - });

              h2 Contact
              a#contact(href='mailto:ktty1220@gmail.com')
                img.favicon(src=favicon('https://mail.google.com/'), alt='Gmail')
                span ktty1220@gmail.com

            div.box
              h2 Development
              div.library
                -
                  var libs = {
                    'cheerio-httpcli': 'iconvによる文字コード変換とcheerioによるHTMLパースを組み込んだNode.js用HTTPクライアントモジュール',
                    'jquery.popn-socialbutton': 'Twitter, Facebook, はてなブックマークのカスタムシェアボタンを表示するjQueryプラグイン',
                    'nanox': 'React用の小規模なFluxライクフレームワーク',
                    'hyperapp-infinite-list': 'Hyperapp用の無限スクロールリストコンポーネント',
                    'gulp-packages': 'gulp package management helper',
                    'jquery.lively-layout': 'HTMLのレイアウト表示をアニメーションで演出するjQueryプラグイン',
                    'lwl': 'ファイル名 & 行番号付きのログを出力するNode.jsモジュール',
                    'cordova-filesystem': 'PhoneGapのファイルAPIを使いやすくするラッパー',
                    'bucome-watcher': 'はてなブックマーク コメント追っかけサービス「ブコメwatcher」のソース',
                    'backbone.cron': 'Backbone.jsにcron機能を実装するクラス',
                    'sqlite3-webapi-kit': 'SQLite3をデータベースサーバー化するNode.js用APIキット',
                    'qilin-daemon': 'Node.jsでホットデプロイをサポートするデーモン',
                    'php-redisutil': 'Redisの様々な型のデータの検索および保存をそれぞれ単一のメソッドで実行するクラス',
                    'face-emotion.js': '表情をアニメーションでコントロールできるニコちゃんマーク風な顔パーツを作成するJavaScriptライブラリ',
                    'vivi': 'PhoneGapなどのHTMLを使用するモバイルアプリ用のフレームワーク',
                    'cordova-plugin-exdialogs': '公式でサポートされていないネイティブダイアログを実装するPhoneGapプラグイン',
                    'cordova-native-menu': 'PhoneGapにAndroidネイティブのメニューを実装するパーツ',
                    'peridot-starter-kit': 'Starter Kit for Peridot PHP testing Framework',
                    'gulp-peridot': 'Peridot PHP Test framework runner for gulp',
                    'mini-socialbutton': 'firefoxのツールバーにはてなブックマークとTwitterのソーシャルカウント付きのボタンを設置するアドオン',

                    'browser-detector.js': 'UserAgentに依存しないブラウザ判定JavaScript',
                    'tiny-totalizer': '連想配列を使用したNode.js用簡易集計モジュール',
                    'mysql-glimit': 'グループ毎に件数を指定して抽出するMySQL UDF'
                  };
                each desc, name in libs
                  div.item
                    - var repo = 'https://github.com/ktty1220/' + name;
                    a.wrap-link(href=repo, target='_blank')
                    h4
                      a(href=repo, target='_blank')
                        img.favicon(src=favicon(repo), alt=name)
                        span #{name}
                    div.desc
                      p
                        a(href=repo, target='_blank') #{desc}
                    div.hubinfo.clearfix
                      span.star

